# --- LLM providers (env-agnostic) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Datadog (env-agnostic; optional — Sherlock works without it) ---
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# --- Multi-env config ---
# Comma-separated list of envs this Sherlock instance can talk to. Adding a new
# env (e.g. prod): append it to SHERLOCK_ENVS, add the corresponding
# <TOOL>_<ENV>_* vars below, drop a self-contained kubeconfig in ~/.kube,
# point KUBECONFIG_<ENV> at it, restart. The frontend dropdown picks it up
# automatically.
SHERLOCK_ENVS=stage,ppe
SHERLOCK_DEFAULT_ENV=ppe

# Optional per-env overrides for the kubectl convention. Sherlock defaults
# k8s_namespace=<env-name> and k8s_pod_suffix=-<env-name>, which matches the
# Trackonomy pattern (PPE pods labeled `app=<service>-ppe`, stage `-stage`).
# Uncomment / set these only if your cluster uses different conventions.
# K8S_PPE_NAMESPACE=ppe
# K8S_PPE_POD_SUFFIX=-ppe
# K8S_STAGE_NAMESPACE=stage
# K8S_STAGE_POD_SUFFIX=-stage

# --- PPE (Trackonomy MSSQL prod-sub, k8s namespace `ppe`) ---
MSSQL_PPE_SERVER=sqlsrvrtrkmtprodalias.database.windows.net
MSSQL_PPE_DATABASE=dbtrkmtppe2
MSSQL_PPE_USER=
MSSQL_PPE_PASSWORD=

COSMOS_PPE_ENDPOINT=
COSMOS_PPE_KEY=
COSMOS_PPE_DATABASE=

# Two ways to configure Redis — pick one (host triplet preferred).
REDIS_PPE_HOST=
REDIS_PPE_PORT=6380
REDIS_PPE_KEY=
REDIS_PPE_TLS=true
REDIS_PPE_URL=

# Path to a self-contained PPE kubeconfig. Generated once by:
#   az aks get-credentials --admin \
#     --subscription trk-mt-prod-sub \
#     --resource-group <ppe-rg> --name <ppe-aks-name> \
#     -f ~/.kube/sherlock-ppe.config
KUBECONFIG_PPE=/Users/<you>/.kube/sherlock-ppe.config

# --- Stage (Trackonomy MSSQL dev-sub, k8s namespace `dev`) ---
# Stage runs in the trk-mt-dev-sub subscription on AKS cluster
# `aks-trk-mt-v2-shared-eastus2` (RG: rg-mt-global-v2-eastus2). The
# kubeconfig at the path below is self-contained (admin cert), so flipping
# envs in the UI never depends on `az account set` or your day-to-day
# subscription context.
MSSQL_STAGE_SERVER=sqlsrvrtrkmtdev.database.windows.net
MSSQL_STAGE_DATABASE=dbtrkmtstg2
MSSQL_STAGE_USER=
MSSQL_STAGE_PASSWORD=

COSMOS_STAGE_ENDPOINT=
COSMOS_STAGE_KEY=
COSMOS_STAGE_DATABASE=

REDIS_STAGE_HOST=
REDIS_STAGE_PORT=6380
REDIS_STAGE_KEY=
REDIS_STAGE_TLS=true
REDIS_STAGE_URL=

KUBECONFIG_STAGE=/Users/<you>/.kube/sherlock-stage.config

# --- Local infra ---
DATABASE_URL=postgresql://sherlock:sherlock_local_dev@localhost:5433/sherlock

# --- Sherlock app ---
SHERLOCK_LOG_LEVEL=INFO
SHERLOCK_RELEASE=ppe
SHERLOCK_INVESTIGATIONS_DIR=./investigations
SHERLOCK_REPOS_DIR=./repos
SHERLOCK_DB_PATH=./sherlock.db

# Set to 1 to run with canned realistic responses (no API calls). Useful for
# demoing the UI without setting up Anthropic/OpenAI/PPE credentials.
# Try queries like "How do I label a white tape?" or "Device AABBCCDDEEFF
# events not in lookup_parcels in PPE".
SHERLOCK_DEMO_MODE=0

# Set to 1 to wipe every session, message, audit entry, and RCA scratch dir
# at server startup. Useful for demo builds that should always launch clean.
# Leave at 0 while developing — server restarts are common and you want chat
# history to survive them. Manual delete (trash icon + "Clear all" in the
# sidebar) works regardless of this flag.
SHERLOCK_EPHEMERAL_SESSIONS=0

# Proactive mode: scheduled health probes that produce briefings (the
# "Briefings" tab in the UI). When enabled, a startup briefing runs on boot
# and a periodic tick fires every SHERLOCK_BRIEFING_INTERVAL_SECONDS.
# Briefings persist across SHERLOCK_EPHEMERAL_SESSIONS=1 wipes.
SHERLOCK_PROACTIVE_ENABLED=0
SHERLOCK_BRIEFING_INTERVAL_SECONDS=21600
SHERLOCK_BRIEFING_ON_STARTUP=1
